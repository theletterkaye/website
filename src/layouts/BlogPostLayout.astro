---
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import KeyTakeaways from '../components/KeyTakeaways.astro';
import AuthorBio from '../components/AuthorBio.astro';

interface Props {
  title: string;
  description: string;
  slug: string;
  publishDate: Date;
  updatedDate?: Date;
  category: string;
  tags: string[];
  excerpt: string;
  image?: string;
  imageAlt?: string;
  imageCredit?: string;
  ogImage?: string;
  metaTitle?: string;
  canonicalUrl?: string;
  keyTakeaways: string[];
  faq: { question: string; answer: string }[];
  tldr: string;
  topics: string[];
}

const {
  title,
  description,
  slug,
  publishDate,
  updatedDate,
  category,
  tags,
  image,
  imageAlt,
  imageCredit,
  ogImage,
  metaTitle,
  canonicalUrl,
  keyTakeaways,
  faq,
  tldr,
  topics,
} = Astro.props;

// Other posts (exclude current)
const otherPosts = (await getCollection('blog'))
  .filter((p) => !p.data.draft && p.data.slug !== slug)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const otherImages = new Map<string, { url: string; alt: string }>();

const pageTitle = metaTitle || `${title} | Kaye Putnam`;
const canonical = canonicalUrl || `https://kayeputnam.com/writing/${slug}`;
const metaImage = ogImage || image || undefined;

const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const updatedFormatted = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Reading time estimate
const slotContent = await Astro.slots.render('default');
const wordCount = slotContent.replace(/<[^>]*>/g, '').split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 250));

// JSON-LD: Article
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  datePublished: publishDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  author: {
    '@type': 'Person',
    name: 'Kaye Putnam',
    url: 'https://kayeputnam.com',
    jobTitle: 'Brand Strategist & Marketing Leader',
    sameAs: [
      'https://www.linkedin.com/in/kayeputnam/',
      'https://www.brandingquiz.com',
    ],
  },
  publisher: {
    '@type': 'Person',
    name: 'Kaye Putnam',
    url: 'https://kayeputnam.com',
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonical,
  },
  keywords: topics,
  articleSection: category,
};

// JSON-LD: FAQ (conditional)
const faqSchema = faq.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faq.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer,
        },
      })),
    }
  : null;
---

<BaseLayout title={pageTitle} description={description} image={metaImage} ogType="article">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    {faqSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    )}
  </Fragment>

  <Nav />

  <main style="padding-top: var(--site-header-height);">
    <article class="post">

      <!-- ========== HERO HEADER — full width, dramatic ========== -->
      <header class:list={['post-hero', { 'post-hero--has-image': !!image }]}>
        {image && <div class="post-hero-bg" style={`background-image: url(${image})`}></div>}
        <div class="post-hero-inner">
          <div class="post-hero-meta">
            <span class="post-hero-category">{category}</span>
            <span class="post-hero-divider" aria-hidden="true"></span>
            <time datetime={publishDate.toISOString()}>{formattedDate}</time>
            {updatedFormatted && <span class="post-hero-updated">Updated {updatedFormatted}</span>}
            <span>{readingTime} min read</span>
          </div>
          <h1 class="post-hero-title">{title}</h1>
          <div class="post-hero-tags">
            {tags.map((t) => (
              <span class="post-hero-tag">{t}</span>
            ))}
          </div>
        </div>
        {imageCredit && <p class="post-hero-credit">{imageCredit}</p>}
      </header>

      <!-- ========== STANDFIRST / TLDR — wider than prose ========== -->
      <div class="post-standfirst">
        <div class="post-standfirst-inner">
          <div class="post-standfirst-rule" aria-hidden="true"></div>
          <p>{tldr}</p>
        </div>
      </div>

      <!-- ========== PROSE BODY ========== -->
      <div class="post-content">
        <div class="post-body">
          <slot />
        </div>
      </div>

      <!-- ========== KEY TAKEAWAYS — breaks wider ========== -->
      {keyTakeaways.length > 0 && (
        <div class="post-takeaways-wrap">
          <KeyTakeaways takeaways={keyTakeaways} />
        </div>
      )}

      <!-- ========== SUBSCRIBE ========== -->
      <div class="post-subscribe">
        <div class="post-subscribe-inner">
          <div class="post-subscribe-text">
            <p class="post-subscribe-heading">Enjoyed this? Stay in the loop.</p>
            <p class="post-subscribe-desc">I share new thinking on brands, AI, and hospitality on an irregular basis.</p>
          </div>
          <script>
            // Load ConvertKit only when the form is near the viewport
            const ckForm = document.querySelector('.formkit-form');
            if (ckForm) {
              const loadCk = () => {
                if (document.getElementById('ck-script')) return;
                const s = document.createElement('script');
                s.src = 'https://f.convertkit.com/ckjs/ck.5.js';
                s.id = 'ck-script';
                document.body.appendChild(s);
              };
              const io = new IntersectionObserver((entries) => {
                if (entries.some((e) => e.isIntersecting)) { loadCk(); io.disconnect(); }
              }, { rootMargin: '400px' });
              io.observe(ckForm);
            }
          </script>
          <form
            action="https://app.kit.com/forms/9207980/subscriptions"
            class="seva-form formkit-form post-subscribe-form"
            method="post"
            data-sv-form="9207980"
            data-uid="53433df288"
            data-format="inline"
            data-version="5"
            data-options={JSON.stringify({"settings":{"after_subscribe":{"action":"message","success_message":"You're in! Check your email to confirm."},"powered_by":{"show":false},"recaptcha":{"enabled":false}},"version":"5"})}
          >
            <div data-style="clean">
              <ul class="formkit-alert formkit-alert-error" data-element="errors" data-group="alert"></ul>
              <div data-element="fields" data-stacked="false" class="seva-fields formkit-fields">
                <div class="formkit-field">
                  <input
                    class="formkit-input post-subscribe-input"
                    name="email_address"
                    aria-label="Email address"
                    placeholder="Your email"
                    required
                    type="email"
                  />
                </div>
                <button data-element="submit" class="formkit-submit btn post-subscribe-btn">
                  <div class="formkit-spinner"><div></div><div></div><div></div></div>
                  <span>Subscribe</span>
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>

      <!-- ========== FOOTER — author + nav ========== -->
      <div class="post-footer-wrap">
        <div class="post-footer-rule" aria-hidden="true"></div>
        <AuthorBio />
      </div>

    </article>

    <!-- ========== MORE WRITING ========== -->
    {otherPosts.length > 0 && (
      <section class="more-writing">
        <div class="more-writing-inner">
          <p class="more-writing-label">More Writing</p>
          <ul class="more-writing-list">
            {otherPosts.map((post) => (
              <li>
                <a href={`/writing/${post.data.slug}`} class="more-writing-row">
                  {(() => {
                    const imgSrc = post.data.image || otherImages.get(post.data.slug)?.url;
                    const imgAlt = post.data.imageAlt || otherImages.get(post.data.slug)?.alt || '';
                    return imgSrc ? (
                      <div class="more-writing-image">
                        <img src={imgSrc} alt={imgAlt} loading="lazy" />
                      </div>
                    ) : (
                      <div class="more-writing-image more-writing-image--placeholder">
                        <span class="more-writing-image-category">{post.data.category}</span>
                      </div>
                    );
                  })()}
                  <h3 class="more-writing-title">{post.data.title}</h3>
                  <span class="more-writing-cta">Read Post</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}
  </main>

  <Footer />
</BaseLayout>

<script>
  // Reveal animations
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );
  document.querySelectorAll('.post-hero-title, .post-standfirst p, .post-hero-meta, .post-hero-tags').forEach((el) => observer.observe(el));

</script>

<style>
  /* ============================================================
     HERO — full-width, oversized display typography
  ============================================================ */
  .post-hero {
    background-color: var(--gray-200);
    padding: var(--space-24) 0 var(--space-16);
    border-bottom: 1px solid var(--gray-300);
    position: relative;
    overflow: hidden;
  }

  .post-hero--has-image {
    background-color: var(--color-ink);
  }

  .post-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0.25;
  }

  .post-hero--has-image .post-hero-meta {
    color: rgba(255, 255, 255, 0.6);
  }

  .post-hero--has-image .post-hero-category {
    color: var(--color-gold);
  }

  .post-hero--has-image .post-hero-divider {
    background-color: rgba(255, 255, 255, 0.25);
  }

  .post-hero--has-image .post-hero-title {
    color: var(--color-cream);
  }

  .post-hero--has-image .post-hero-tag {
    color: rgba(255, 255, 255, 0.6);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .post-hero-credit {
    position: absolute;
    bottom: var(--space-3);
    right: var(--container-fluid-margin);
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.35);
    letter-spacing: 0.02em;
  }

  .post-hero-inner {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--container-fluid-margin);
    position: relative;
  }

  .post-hero-meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    font-size: var(--text-sm);
    color: var(--gray-400);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: var(--weight-medium);
    margin-bottom: var(--space-8);
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.6s var(--easing-editorial), transform 0.6s var(--easing-editorial);
  }

  .post-hero-meta.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .post-hero-category {
    color: var(--color-gold);
    font-weight: var(--weight-semi);
  }

  .post-hero-divider {
    width: 24px;
    height: 1px;
    background-color: var(--gray-300);
  }

  .post-hero-updated {
    color: var(--color-gold);
  }

  .post-hero-title {
    font-size: clamp(var(--text-3xl), 5.5vw, 5rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    max-width: 18ch;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s var(--easing-editorial) 0.1s, transform 0.8s var(--easing-editorial) 0.1s;
  }

  .post-hero-title.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .post-hero-tags {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-8);
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.6s var(--easing-editorial) 0.25s, transform 0.6s var(--easing-editorial) 0.25s;
  }

  .post-hero-tags.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .post-hero-tag {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--gray-500);
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--gray-300);
    border-radius: var(--radius-full);
  }

  /* ============================================================
     STANDFIRST — wider column, editorial pull-quote feel
  ============================================================ */
  .post-standfirst {
    background-color: var(--color-cream);
    padding: var(--space-16) 0 var(--space-20);
  }

  .post-standfirst-inner {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--container-fluid-margin);
  }

  .post-standfirst-rule {
    width: 48px;
    height: 2px;
    background-color: var(--color-gold);
    margin-bottom: var(--space-8);
  }

  .post-standfirst p {
    font-family: var(--ff-heading);
    font-size: clamp(var(--text-xl), 2.5vw, var(--text-2xl));
    line-height: var(--leading-snug);
    color: var(--gray-700);
    max-width: none;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.8s var(--easing-editorial) 0.15s, transform 0.8s var(--easing-editorial) 0.15s;
  }

  .post-standfirst p.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ============================================================
     PROSE BODY — tighter column for reading, editorial spacing
  ============================================================ */
  .post-content {
    background-color: var(--color-cream);
    padding-bottom: var(--space-6);
  }

  .post-body {
    max-width: 960px;
    margin-inline: auto;
    padding-inline: var(--container-fluid-margin);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
  }

  .post-body :global(p:first-child) {
    font-size: var(--text-xl);
  }

  /* H2 — oversized, breaks rhythm */
  .post-body :global(h2) {
    font-size: clamp(var(--text-2xl), 3vw, var(--text-3xl));
    line-height: var(--leading-tight);
    margin-top: var(--space-20);
    margin-bottom: var(--space-6);
    padding-top: var(--space-12);
    position: relative;
  }

  .post-body :global(h2)::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 32px;
    height: 2px;
    background-color: var(--color-gold);
  }

  .post-body :global(h3) {
    font-size: var(--text-xl);
    line-height: var(--leading-snug);
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
  }

  .post-body :global(p) {
    margin-bottom: var(--space-6);
    max-width: none;
  }

  /* First paragraph — slightly larger */
  .post-body :global(p:first-child) {
    font-size: var(--text-md);
  }

  .post-body :global(a) {
    color: var(--color-gold);
    text-decoration: underline;
    text-decoration-color: rgba(153, 97, 22, 0.3);
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: text-decoration-color var(--duration-base) var(--easing-standard);
  }

  .post-body :global(a:hover) {
    text-decoration-color: var(--color-gold);
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    margin-bottom: var(--space-6);
    padding-left: var(--space-6);
  }

  .post-body :global(li) {
    margin-bottom: var(--space-3);
  }

  .post-body :global(li::marker) {
    color: var(--color-gold);
  }

  .post-body :global(blockquote) {
    border-left: none;
    background: none;
    padding: var(--space-8) 0;
    margin: var(--space-12) calc(var(--container-fluid-margin) * -1);
    padding-inline: var(--container-fluid-margin);
    position: relative;
  }

  .post-body :global(blockquote)::before {
    content: '';
    position: absolute;
    left: var(--container-fluid-margin);
    top: 0;
    width: 32px;
    height: 2px;
    background-color: var(--color-gold);
  }

  .post-body :global(blockquote p) {
    font-family: var(--ff-heading);
    font-size: var(--text-2xl);
    line-height: var(--leading-snug);
    color: var(--color-ink);
    font-style: normal;
  }

  .post-body :global(strong) {
    font-weight: var(--weight-semi);
    color: var(--color-ink);
  }

  .post-body :global(hr) {
    border: none;
    height: 2px;
    width: 32px;
    background-color: var(--color-gold);
    margin: var(--space-16) auto;
  }

  /* ============================================================
     KEY TAKEAWAYS — wider breakout
  ============================================================ */
  .post-takeaways-wrap {
    max-width: 960px;
    margin-inline: auto;
    padding-inline: var(--container-fluid-margin);
    padding-bottom: var(--space-12);
  }

  /* ============================================================
     FOOTER — author bio + back nav
  ============================================================ */
  .post-footer-wrap {
    max-width: 960px;
    margin-inline: auto;
    padding-inline: var(--container-fluid-margin);
    padding-bottom: var(--space-24);
  }

  .post-footer-rule {
    height: 1px;
    background-color: var(--gray-300);
    margin-bottom: var(--space-12);
  }

  /* ============================================================
     MORE WRITING — horizontal row layout
  ============================================================ */
  .more-writing {
    background-color: var(--color-cream);
    padding: var(--space-20) 0 var(--space-24);
    border-top: 1px solid var(--gray-300);
  }

  .more-writing-inner {
    max-width: 960px;
    margin-inline: auto;
    padding-inline: var(--container-fluid-margin);
  }

  .more-writing-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semi);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray-400);
    margin-bottom: var(--space-8);
  }

  .more-writing-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .more-writing-list li {
    border-top: 1px solid var(--gray-300);
  }

  .more-writing-list li:last-child {
    border-bottom: 1px solid var(--gray-300);
  }

  .more-writing-row {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    gap: var(--space-8);
    align-items: center;
    padding: var(--space-6) 0;
    color: var(--color-ink);
    transition: opacity var(--duration-base) var(--easing-standard);
  }

  .more-writing-row:hover {
    opacity: 0.7;
  }

  .more-writing-image {
    width: 100px;
    height: 72px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background-color: var(--gray-200);
    box-shadow: 0 0 0 1px rgba(153, 97, 22, 0.15);
    flex-shrink: 0;
  }

  .more-writing-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .more-writing-image--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .more-writing-image-category {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--gray-400);
    text-align: center;
    padding: var(--space-2);
    line-height: var(--leading-snug);
  }

  .more-writing-title {
    font-family: var(--ff-heading);
    font-size: clamp(var(--text-lg), 2vw, var(--text-2xl));
    line-height: var(--leading-snug);
    font-weight: var(--weight-regular);
  }

  .more-writing-cta {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--gray-400);
    white-space: nowrap;
  }

  /* ============================================================
     INLINE SUBSCRIBE
  ============================================================ */
  .post-subscribe {
    max-width: 960px;
    margin-inline: auto;
    padding-inline: var(--container-fluid-margin);
    padding-bottom: var(--space-16);
  }

  .post-subscribe-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
    padding: var(--space-8) var(--space-10);
    background-color: var(--color-forest);
    border-radius: var(--radius-lg);
  }

  .post-subscribe-text {
    flex: 1;
    min-width: 0;
  }

  .post-subscribe-heading {
    font-family: var(--ff-heading);
    font-size: var(--text-xl);
    color: var(--color-cream);
    margin-bottom: var(--space-1);
  }

  .post-subscribe-desc {
    font-size: var(--text-sm);
    color: var(--color-blush);
    opacity: 0.7;
    line-height: var(--leading-relaxed);
    max-width: none;
  }

  .post-subscribe-form {
    flex-shrink: 0;
    max-width: none !important;
  }

  .post-subscribe-form [data-style="clean"] {
    padding: 0 !important;
  }

  .post-subscribe-form .formkit-fields {
    display: flex !important;
    gap: var(--space-3) !important;
    flex-wrap: nowrap !important;
    margin: 0 !important;
  }

  .post-subscribe-form .formkit-field {
    flex: 0 0 auto !important;
    margin: 0 !important;
  }

  .post-subscribe-form .formkit-input.post-subscribe-input {
    height: var(--btn-height) !important;
    padding: 0 var(--space-5) !important;
    border-radius: var(--radius-full) !important;
    border: 1px solid var(--gray-300) !important;
    background-color: var(--color-cream) !important;
    font-family: var(--ff-body) !important;
    font-size: var(--text-base) !important;
    color: var(--color-ink) !important;
    width: 220px !important;
    line-height: var(--btn-height) !important;
    transition: border-color var(--duration-base) var(--easing-standard);
  }

  .post-subscribe-form .formkit-input.post-subscribe-input::placeholder {
    color: var(--gray-400) !important;
    opacity: 1 !important;
  }

  .post-subscribe-form .formkit-input.post-subscribe-input:focus {
    outline: none !important;
    border-color: var(--color-gold) !important;
  }

  .post-subscribe-form .formkit-submit.post-subscribe-btn {
    --btn-bg-color: var(--color-ink);
    --btn-border-color: var(--color-ink);
    margin: 0 !important;
    flex: 0 0 auto !important;
  }

  .post-subscribe-form .formkit-submit.post-subscribe-btn > span {
    padding: 0 var(--btn-padding-x) !important;
    line-height: var(--btn-height) !important;
  }

  .post-subscribe-form .formkit-spinner {
    display: none;
