---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Section from '../../components/Section.astro';
import Stat from '../../components/Stat.astro';

export async function getStaticPaths() {
  const casestudies = await getCollection('casestudies');
  return casestudies.map(cs => ({
    params: { slug: cs.id },
    props: { entry: cs },
  }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);

// Get all case studies for next/prev navigation
const allCaseStudies = await getCollection('casestudies');
const sorted = allCaseStudies.sort((a, b) => a.data.order - b.data.order);
const currentIndex = sorted.findIndex(cs => cs.id === entry.id);
const nextStudy = sorted[(currentIndex + 1) % sorted.length];
---

<BaseLayout
  title={`${data.title} — Kaye Putnam`}
  description={data.description}
>

  <Nav currentPath="/work" />

  <main style="padding-top: var(--site-header-height);">

    <!-- ============================================================
         HERO
    ============================================================ -->
    <section class="cs-hero">
      <div class="container cs-hero-inner">
        <div class="cs-hero-content">
          <a href="/work" class="cs-back hero-item">← All work</a>
          <h1 class="cs-hero-title hero-item">{data.title}</h1>
          <p class="cs-hero-desc hero-item">{data.description}</p>
          <div class="cs-hero-pillars hero-item">
            {data.pillars.map(pillar => (
              <span class="tag tag--gold">{pillar}</span>
            ))}
          </div>
        </div>
        {data.heroImage && (
          <div class="cs-hero-image hero-photo-animate">
            <img src={data.heroImage} alt={data.heroImageAlt || ''} loading="eager" />
          </div>
        )}
      </div>
    </section>

    <!-- ============================================================
         AT A GLANCE
    ============================================================ -->
    <div class="glance-bar">
      <div class="container glance-inner">
        <div class="glance-item">
          <span class="glance-label">Role</span>
          <span class="glance-value">{data.role}</span>
        </div>
        <div class="glance-divider" aria-hidden="true"></div>
        <div class="glance-item">
          <span class="glance-label">Timeline</span>
          <span class="glance-value">{data.timeline}</span>
        </div>
        <div class="glance-divider" aria-hidden="true"></div>
        <div class="glance-item">
          <span class="glance-label">Industry</span>
          <span class="glance-value">{data.industry}</span>
        </div>
      </div>
    </div>

    <!-- ============================================================
         THE CHALLENGE
    ============================================================ -->
    <Section variant="default" size="xl">
      <div class="cs-section reveal">
        <div class="cs-section-label">
          <span class="label">The Challenge</span>
        </div>
        <div class="cs-section-content">
          <p class="cs-body-text">{data.challenge}</p>
        </div>
      </div>
    </Section>

    <!-- ============================================================
         THE INSIGHT
    ============================================================ -->
    <Section variant="cream" size="lg">
      <div class="cs-insight reveal">
        <span class="label" style="margin-bottom: var(--space-6);">The Insight</span>
        <blockquote>
          <p>{data.insight}</p>
        </blockquote>
      </div>
    </Section>

    <!-- ============================================================
         THE APPROACH
    ============================================================ -->
    <Section variant="default" size="xl">
      <div class="cs-section reveal">
        <div class="cs-section-label">
          <span class="label">The Approach</span>
        </div>
        <div class="cs-section-content">
          <p class="cs-body-text">{data.approach}</p>
        </div>
      </div>
    </Section>

    <!-- ============================================================
         THE WORK (rendered from markdown body)
    ============================================================ -->
    <Section variant="warm" size="xl">
      <div class="cs-section reveal">
        <div class="cs-section-label">
          <span class="label">The Work</span>
        </div>
        <div class="cs-section-content cs-work-content">
          <Content />
        </div>
      </div>
    </Section>

    <!-- ============================================================
         THE RESULTS
    ============================================================ -->
    <Section variant="default" size="xl">
      <div class="cs-section reveal">
        <div class="cs-section-label">
          <span class="label">The Results</span>
        </div>
        <div class="cs-section-content">
          <div class="cs-results-grid">
            {data.results.map(result => (
              <Stat value={result.stat} label={result.label} variant="card" />
            ))}
          </div>
        </div>
      </div>
    </Section>

    <!-- ============================================================
         REFLECTION
    ============================================================ -->
    <Section variant="cream" size="lg">
      <div class="cs-insight reveal">
        <span class="label" style="margin-bottom: var(--space-6);">Reflection</span>
        <blockquote>
          <p>{data.reflection}</p>
        </blockquote>
      </div>
    </Section>

    <!-- ============================================================
         NEXT CASE STUDY
    ============================================================ -->
    {nextStudy && nextStudy.id !== entry.id && (
      <Section variant="dark" size="xl">
        <div class="cs-next reveal">
          <span class="label" style="margin-bottom: var(--space-4);">Next case study</span>
          <a href={`/work/${nextStudy.id}`} class="cs-next-link">
            <h2>{nextStudy.data.title}</h2>
            <span class="cs-next-arrow">→</span>
          </a>
          <p style="margin-top: var(--space-4); max-width: 52ch;">{nextStudy.data.description}</p>
        </div>
      </Section>
    )}

  </main>

  <Footer />

</BaseLayout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0, rootMargin: '0px 0px -60px 0px' }
  );

  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

  // Scrolling screenshot frames
  const scrollFrames = document.querySelectorAll('.img-screenshot--scroll');
  if (scrollFrames.length > 0) {
    function updateScrollFrames() {
      scrollFrames.forEach((frame) => {
        const img = frame.querySelector('img') as HTMLElement;
        if (!img) return;
        const rect = frame.getBoundingClientRect();
        const viewportH = window.innerHeight;
        // progress: 0 until frame top reaches halfway down viewport, then scrolls over one viewport height
        const startAt = viewportH / 2;
        const progress = Math.max(0, Math.min(1, (startAt - rect.top) / viewportH));
        const chromePadding = 42; // 32px top + 10px bottom
        const maxTranslate = img.offsetHeight - (frame.clientHeight - chromePadding);
        img.style.transform = `translateY(${-progress * maxTranslate}px)`;
      });
    }
    window.addEventListener('scroll', updateScrollFrames, { passive: true });
    updateScrollFrames();
  }
</script>

<style>
  /* ============================================================
     HERO ENTRANCE
  ============================================================ */
  @keyframes hero-fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero-item {
    animation: hero-fade-up 0.8s cubic-bezier(0.55, 0.21, 0.07, 0.87) both;
  }
  .hero-item:nth-child(1) { animation-delay:  80ms; }
  .hero-item:nth-child(2) { animation-delay: 200ms; }
  .hero-item:nth-child(3) { animation-delay: 320ms; }
  .hero-item:nth-child(4) { animation-delay: 440ms; }

  .hero-photo-animate {
    animation: hero-fade-up 1s cubic-bezier(0.55, 0.21, 0.07, 0.87) 180ms both;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-item, .hero-photo-animate { animation: none; }
  }

  /* ============================================================
     CASE STUDY HERO
  ============================================================ */
  .cs-hero {
    background-color: var(--color-cream);
    padding-block: var(--space-16) var(--space-12);
  }

  .cs-hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  .cs-hero-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .cs-back {
    font-family: var(--ff-body);
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--gray-400);
    margin-bottom: var(--space-2);
  }

  .cs-back:hover {
    color: var(--color-gold);
  }

  .cs-hero-title {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    line-height: var(--leading-tight);
    letter-spacing: 0.01em;
  }

  .cs-hero-desc {
    font-size: var(--text-lg);
    color: var(--gray-700);
    line-height: var(--leading-relaxed);
    max-width: 48ch;
  }

  .cs-hero-pillars {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-top: var(--space-2);
  }

  .cs-hero-image {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background-color: var(--gray-200);
  }

  .cs-hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ============================================================
     AT A GLANCE BAR
  ============================================================ */
  .glance-bar {
    background-color: var(--gray-100);
    border-top: 1px solid rgba(153, 97, 22, 0.15);
    border-bottom: 1px solid rgba(153, 97, 22, 0.15);
    padding-block: var(--space-8);
  }

  .glance-inner {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-16);
    flex-wrap: wrap;
  }

  .glance-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    text-align: center;
  }

  .glance-label {
    font-family: var(--ff-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-gold);
  }

  .glance-value {
    font-family: var(--ff-heading);
    font-size: var(--text-lg);
    color: var(--color-ink);
  }

  .glance-divider {
    width: 1px;
    height: 40px;
    background-color: var(--gray-300);
    flex-shrink: 0;
  }

  /* ============================================================
     CONTENT SECTIONS
  ============================================================ */
  .cs-section {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: var(--space-16);
    align-items: start;
  }

  .cs-body-text {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    max-width: 64ch;
  }

  /* ============================================================
     INSIGHT / REFLECTION (centered blockquote)
  ============================================================ */
  .cs-insight {
    max-width: 720px;
    margin-inline: auto;
    text-align: center;
  }

  .cs-insight blockquote {
    border-left: none;
    background: none;
    padding: 0;
    margin: 0;
  }

  .cs-insight blockquote p {
    font-family: var(--ff-heading);
    font-size: var(--text-2xl);
    line-height: var(--leading-snug);
    color: var(--color-ink);
    max-width: none;
    text-align: center;
  }

  /* ============================================================
     THE WORK (markdown content)
  ============================================================ */
  .cs-work-content :global(p) {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    max-width: 64ch;
    margin-bottom: var(--space-6);
  }

  .cs-work-content :global(img) {
    border-radius: var(--radius-lg);
    margin-block: var(--space-8);
  }

  /* H2 = work sub-section headings */
  .cs-work-content :global(h2) {
    font-size: var(--text-2xl);
    line-height: var(--leading-tight);
    margin-top: var(--space-20);
    margin-bottom: var(--space-4);
  }

  .cs-work-content :global(h2:first-child) {
    margin-top: 0;
  }

  /* H3 = image grid label */
  .cs-work-content :global(h3) {
    font-family: var(--ff-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-gold);
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
  }

  /* Image grids: use <p> tags with multiple images for 2-col, 3-col layouts */
  /* 2-column image grid */
  .cs-work-content :global(.img-grid-2) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-block: var(--space-6);
  }

  .cs-work-content :global(.img-grid-2 img) {
    margin: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 4 / 3;
  }

  /* 3-column image grid */
  .cs-work-content :global(.img-grid-3) {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: var(--space-4);
    margin-block: var(--space-6);
  }

  .cs-work-content :global(.img-grid-3 img) {
    margin: 0;
    width: 100%;
    object-fit: contain;
    background-color: var(--color-cream);
    padding: var(--space-6);
  }

  .cs-work-content :global(.img-grid-3--square img) {
    aspect-ratio: 1 / 1;
    padding: var(--space-10);
  }

  /* Feature image — full width, taller */
  .cs-work-content :global(.img-feature) {
    margin-block: var(--space-8);
  }

  .cs-work-content :global(.img-feature img) {
    margin: 0;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  /* Side-by-side: image + image at different ratios */
  .cs-work-content :global(.img-pair) {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-4);
    margin-block: var(--space-6);
    align-items: start;
  }

  .cs-work-content :global(.img-pair img) {
    margin: 0;
    width: 100%;
    border-radius: var(--radius-lg);
  }

  /* Scrolling screenshot — full-page screenshot that scrolls within the frame */
  .cs-work-content :global(.img-screenshot--scroll) {
    height: 500px;
    overflow: hidden;
  }

  @media (max-width: 767px) {
    .cs-work-content :global(.img-screenshot--scroll) {
      height: 340px;
    }
  }

  .cs-work-content :global(.img-screenshot--scroll img) {
    will-change: transform;
  }

  /* Screenshot/device frame treatment — desktop (90s chrome) */
  .cs-work-content :global(.img-screenshot) {
    position: relative;
    background: #e2ddd8;
    border: 2px solid var(--gray-400);
    border-radius: var(--radius-lg);
    padding: 32px 10px 10px;
    margin-block: var(--space-8);
  }

  /* Three title-bar dots */
  .cs-work-content :global(.img-screenshot)::before {
    content: '';
    position: absolute;
    top: 11px;
    left: 14px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--gray-400);
    box-shadow: 14px 0 0 var(--gray-400), 28px 0 0 var(--gray-400);
  }

  .cs-work-content :global(.img-screenshot img) {
    display: block;
    margin: 0;
    width: 100%;
    border-radius: 6px;
    border: 1px solid var(--gray-300);
  }

  /* Screenshot/device frame treatment — phone (iPhone double border) */
  .cs-work-content :global(.img-screenshot-phone) {
    display: inline-block;
    border: 2px solid var(--gray-300);
    border-radius: 26px;
    padding: 7px;
    margin-block: var(--space-4);
    vertical-align: top;
  }

  .cs-work-content :global(.img-screenshot-phone img) {
    display: block;
    margin: 0;
    width: 100%;
    border-radius: 20px;
    border: 2px solid var(--gray-300);
  }

  /* Compact paragraph under section headings */
  .cs-work-content :global(h2 + p) {
    margin-bottom: var(--space-4);
  }

  /* Podcast / link list (mirrors blog "More Writing" pattern) */
  .cs-work-content :global(.podcast-list) {
    list-style: none;
    padding: 0;
    margin: var(--space-6) 0;
  }

  .cs-work-content :global(.podcast-list li) {
    border-top: 1px solid var(--gray-300);
  }

  .cs-work-content :global(.podcast-list li:last-child) {
    border-bottom: 1px solid var(--gray-300);
  }

  .cs-work-content :global(.podcast-row) {
    display: grid;
    grid-template-columns: 64px 1fr auto;
    gap: var(--space-6);
    align-items: center;
    padding: var(--space-5) 0;
    color: var(--color-ink);
    text-decoration: none;
    transition: opacity var(--duration-base) var(--easing-standard);
  }

  .cs-work-content :global(.podcast-row:hover) {
    opacity: 0.7;
  }

  .cs-work-content :global(.podcast-ep) {
    font-size: var(--text-xs);
    font-weight: var(--weight-semi);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    white-space: nowrap;
  }

  .cs-work-content :global(.podcast-title) {
    font-family: var(--ff-heading);
    font-size: clamp(var(--text-base), 1.8vw, var(--text-xl));
    line-height: var(--leading-snug);
    font-weight: var(--weight-regular);
  }

  .cs-work-content :global(.podcast-cta) {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--gray-400);
    white-space: nowrap;
  }

  @media (max-width: 767px) {
    .cs-work-content :global(.img-grid-2),
    .cs-work-content :global(.img-pair) {
      grid-template-columns: 1fr;
    }

    .cs-work-content :global(.img-grid-3) {
      grid-template-columns: 1fr 1fr;
    }

    .cs-work-content :global(h2) {
      margin-top: var(--space-12);
    }

    .cs-work-content :global(.podcast-row) {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }

    .cs-work-content :global(.podcast-cta) {
      display: none;
    }
  }

  /* ============================================================
     RESULTS GRID
  ============================================================ */
  .cs-results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-6);
  }

  /* ============================================================
     NEXT CASE STUDY
  ============================================================ */
  .cs-next {
    max-width: 640px;
  }

  .cs-next-link {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    color: var(--color-cream);
  }

  .cs-next-link:hover {
    color: var(--color-gold);
  }

  .cs-next-link h2 {
    color: inherit;
  }

  .cs-next-arrow {
    font-family: var(--ff-heading);
    font-size: var(--text-3xl);
    transition: transform var(--duration-base) var(--easing-standard);
  }

  .cs-next-link:hover .cs-next-arrow {
    transform: translateX(6px);
  }

  /* ============================================================
     RESPONSIVE
  ============================================================ */
  @media (max-width: 1023px) {
    .cs-hero-inner {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }

    .cs-section {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
  }

  @media (max-width: 767px) {
    .glance-inner {
      gap: var(--space-8);
    }

    .glance-divider {
      display: none;
    }

    .cs-insight blockquote p {
      font-size: var(--text-xl);
    }
  }
</style>
