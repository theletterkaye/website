---
import { getCollection, render } from 'astro:content';
import BlogPostLayout from '../../layouts/BlogPostLayout.astro';
import { getPostImage } from '../../lib/unsplash';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Fetch Unsplash image if post doesn't have one set manually
const unsplashImage = !post.data.image
  ? await getPostImage(post.data.slug, post.data.category)
  : null;
---

<BlogPostLayout
  {...post.data}
  image={unsplashImage?.url || post.data.image}
  imageAlt={unsplashImage?.alt || post.data.imageAlt}
  imageCredit={unsplashImage?.credit}
>
  <Content />
</BlogPostLayout>
