---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const allPosts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const [featured, ...listPosts] = allPosts;

function getPostImage(post: (typeof allPosts)[number]) {
  return post.data.image || null;
}
function getPostImageAlt(post: (typeof allPosts)[number]) {
  return post.data.imageAlt || '';
}
function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout
  title="Writing | Kaye Putnam"
  description="Thinking on brand strategy, AI in marketing, and what it actually takes to build something people remember."
>
  <Nav />

  <main style="padding-top: var(--site-header-height);">

    <!-- ========== PAGE HEADER ========== -->
    <header class="writing-header">
      <div class="writing-header-inner">
        <h1>Writing</h1>
        <p>What I'm noticing about brand strategy, AI in marketing, and what it actually takes to build something people remember.</p>
      </div>
    </header>

    <!-- ========== FEATURED POST ========== -->
    {featured && (() => {
      const imgSrc = getPostImage(featured);
      const imgAlt = getPostImageAlt(featured);
      return (
        <section class="featured-section">
          <a
            href={`/writing/${featured.data.slug}`}
            class:list={['featured-post', { 'featured-post--has-image': !!imgSrc }]}
          >
            <div class="featured-content">
              <div class="featured-eyebrow">
                <span class="featured-category">{featured.data.category}</span>
                <span class="featured-divider" aria-hidden="true"></span>
                <time datetime={featured.data.publishDate.toISOString()}>{formatDate(featured.data.publishDate)}</time>
              </div>
              <h2 class="featured-title">{featured.data.title}</h2>
              {featured.data.excerpt && (
                <p class="featured-excerpt">{featured.data.excerpt}</p>
              )}
              <span class="featured-cta">Read Post →</span>
            </div>
            {imgSrc && (
              <div class="featured-image">
                <img src={imgSrc} alt={imgAlt} loading="eager" />
              </div>
            )}
          </a>
        </section>
      );
    })()}

    <!-- ========== POSTS LIST ========== -->
    {listPosts.length > 0 && (
      <section class="posts-list-section">
        <div class="posts-list-inner">
          <p class="posts-list-label">All Posts</p>
          <ul class="posts-list">
            {listPosts.map((post) => {
              const imgSrc = getPostImage(post);
              const imgAlt = getPostImageAlt(post);
              return (
                <li>
                  <a href={`/writing/${post.data.slug}`} class="post-row">
                    <div class="post-row-image">
                      {imgSrc
                        ? <img src={imgSrc} alt={imgAlt} loading="lazy" />
                        : <span class="post-row-placeholder">{post.data.category}</span>
                      }
                    </div>
                    <div class="post-row-body">
                      <div class="post-row-meta">
                        <span class="post-row-category">{post.data.category}</span>
                        <span class="post-row-dot" aria-hidden="true"></span>
                        <time datetime={post.data.publishDate.toISOString()}>{formatDate(post.data.publishDate)}</time>
                      </div>
                      <h3 class="post-row-title">{post.data.title}</h3>
                      {post.data.excerpt && (
                        <p class="post-row-excerpt">{post.data.excerpt}</p>
                      )}
                      {post.data.tags?.[0] && (
                        <span class="post-row-tag">{post.data.tags[0]}</span>
                      )}
                    </div>
                    <span class="post-row-cta" aria-hidden="true">Read →</span>
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      </section>
    )}

  </main>

  <Footer />
</BaseLayout>

<style>
  /* ============================================================
     PAGE HEADER
  ============================================================ */
  .writing-header {
    background-color: var(--color-cream);
    border-bottom: 1px solid var(--gray-300);
    padding-block: var(--space-32);
  }

  .writing-header-inner {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--container-fluid-margin);
  }

  .writing-header h1 {
    margin-bottom: var(--space-4);
  }

  .writing-header p {
    font-size: var(--text-lg);
    color: var(--gray-700);
    line-height: var(--leading-relaxed);
    max-width: 56ch;
  }

  /* ============================================================
     FEATURED POST — full-bleed ink section
  ============================================================ */
  .featured-section {
    background-color: var(--color-ink);
    border-radius: 48px 48px 0 0;
    padding: var(--space-12) 0 var(--space-16);
  }

  .featured-post {
    display: grid;
    grid-template-columns: 1fr;
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--container-fluid-margin);
    color: var(--color-cream);
    gap: var(--space-12);
    transition: opacity var(--duration-base) var(--easing-standard);
  }

  .featured-post--has-image {
    grid-template-columns: 1fr 44%;
    align-items: center;
  }

  .featured-post:hover {
    opacity: 0.85;
  }

  .featured-content {
    display: flex;
    flex-direction: column;
  }

  /* When no image, constrain the text width */
  .featured-post:not(.featured-post--has-image) .featured-content {
    max-width: 780px;
  }

  .featured-eyebrow {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(247, 247, 245, 0.45);
    margin-bottom: var(--space-6);
  }

  .featured-category {
    color: var(--color-gold);
  }

  .featured-divider {
    width: 20px;
    height: 1px;
    background-color: rgba(247, 247, 245, 0.2);
    flex-shrink: 0;
  }

  .featured-title {
    font-size: clamp(var(--text-3xl), 4.5vw, 3.75rem);
    line-height: 1.06;
    letter-spacing: -0.015em;
    color: var(--color-cream);
    max-width: 22ch;
    margin-bottom: var(--space-8);
  }

  .featured-excerpt {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: rgba(247, 247, 245, 0.55);
    max-width: 52ch;
    margin-bottom: var(--space-10);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .featured-cta {
    font-family: var(--ff-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-semi);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-gold);
    align-self: flex-start;
  }

  .featured-image {
    overflow: hidden;
    border-radius: var(--radius-lg);
    aspect-ratio: 4 / 3;
  }

  .featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ============================================================
     POSTS LIST — editorial rows
  ============================================================ */
  .posts-list-section {
    background-color: var(--color-cream);
    padding: var(--space-16) 0 var(--space-24);
  }

  .posts-list-inner {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--container-fluid-margin);
  }

  .posts-list-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semi);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray-400);
    margin-bottom: var(--space-8);
  }

  .posts-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .posts-list li {
    border-top: 1px solid var(--gray-300);
  }

  .posts-list li:last-child {
    border-bottom: 1px solid var(--gray-300);
  }

  .post-row {
    display: grid;
    grid-template-columns: 180px 1fr auto;
    gap: var(--space-8);
    align-items: center;
    padding: var(--space-8) 0;
    color: var(--color-ink);
    transition: opacity var(--duration-base) var(--easing-standard);
  }

  .post-row:hover {
    opacity: 0.65;
  }

  .post-row-image {
    width: 180px;
    height: 130px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background-color: var(--gray-200);
    box-shadow: 0 0 0 1px rgba(153, 97, 22, 0.12);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .post-row-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post-row-placeholder {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--gray-400);
    text-align: center;
    padding: var(--space-2);
    line-height: var(--leading-snug);
  }

  .post-row-body {
    min-width: 0;
  }

  .post-row-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--gray-500);
    margin-bottom: var(--space-3);
  }

  .post-row-category {
    color: var(--color-gold);
  }

  .post-row-dot {
    width: 3px;
    height: 3px;
    border-radius: var(--radius-full);
    background-color: var(--gray-400);
    flex-shrink: 0;
  }

  .post-row-title {
    font-family: var(--ff-heading);
    font-size: clamp(var(--text-xl), 2.2vw, var(--text-2xl));
    line-height: var(--leading-snug);
    font-weight: var(--weight-regular);
    margin-bottom: var(--space-3);
  }

  .post-row-excerpt {
    font-size: var(--text-base);
    color: var(--gray-600);
    line-height: var(--leading-relaxed);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    max-width: none;
    margin-bottom: var(--space-3);
  }

  .post-row-tag {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--gray-500);
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--gray-300);
    border-radius: var(--radius-full);
    display: inline-block;
  }

  .post-row-cta {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--gray-400);
    white-space: nowrap;
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }

  /* ============================================================
     RESPONSIVE
  ============================================================ */
  @media (max-width: 1023px) {
    .featured-post--has-image {
      grid-template-columns: 1fr 42%;
    }

    .featured-title {
      font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
    }
  }

  @media (max-width: 767px) {
    .featured-section {
      border-radius: 24px 24px 0 0;
      padding: var(--space-10) 0 var(--space-12);
    }

    .featured-post,
    .featured-post--has-image {
      grid-template-columns: 1fr;
      padding-inline: var(--container-fluid-margin);
      gap: var(--space-8);
    }

    .featured-image {
      order: -1;
      border-radius: var(--radius-lg);
      aspect-ratio: 16 / 9;
    }

    .featured-title {
      font-size: var(--text-2xl);
    }

    .featured-excerpt {
      font-size: var(--text-base);
      -webkit-line-clamp: 2;
    }

    .post-row {
      grid-template-columns: 110px 1fr;
      gap: var(--space-5);
      align-items: start;
      padding: var(--space-6) 0;
    }

    .post-row-image {
      width: 110px;
      height: 82px;
    }

    .post-row-excerpt {
      display: none;
    }

    .post-row-tag {
      display: none;
    }

    .post-row-cta {
      display: none;
    }
  }
</style>
