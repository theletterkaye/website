---
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Section from '../../components/Section.astro';

import archetypeCaregiver from '../../assets/archetypes/caregiver.png';
import archetypeCreator from '../../assets/archetypes/creator.png';
import archetypeEntertainer from '../../assets/archetypes/entertainer.png';
import archetypeEveryman from '../../assets/archetypes/everyman.png';
import archetypeExplorer from '../../assets/archetypes/explorer.png';
import archetypeHero from '../../assets/archetypes/hero.png';
import archetypeInnocent from '../../assets/archetypes/innocent.png';
import archetypeLover from '../../assets/archetypes/lover.png';
import archetypeMagician from '../../assets/archetypes/magician.png';
import archetypeMaverick from '../../assets/archetypes/maverick.png';
import archetypeRoyal from '../../assets/archetypes/royal.png';
import archetypeSage from '../../assets/archetypes/sage.png';

const icons: Record<string, ImageMetadata> = {
  caregiver: archetypeCaregiver,
  creator: archetypeCreator,
  entertainer: archetypeEntertainer,
  everyman: archetypeEveryman,
  explorer: archetypeExplorer,
  hero: archetypeHero,
  innocent: archetypeInnocent,
  lover: archetypeLover,
  magician: archetypeMagician,
  maverick: archetypeMaverick,
  royal: archetypeRoyal,
  sage: archetypeSage,
};

export async function getStaticPaths() {
  const archetypes = await getCollection('archetypes');
  return archetypes.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);

const icon = icons[data.icon];

const siblings = (await getCollection('archetypes'))
  .sort((a, b) => a.data.order - b.data.order)
  .filter((a) => a.data.slug !== data.slug);
---

<BaseLayout
  title={`${data.name} Brand Archetype: Traits & Examples | Kaye Putnam`}
  description={data.description}
>

  <Nav currentPath="/brand-archetypes" />

  <main style="padding-top: var(--site-header-height);">

    <!-- ============================================================
         HERO
    ============================================================ -->
    <section class="arch-hero">
      <div class="container arch-hero-inner">
        <div class="arch-hero-content">
          <a href="/brand-archetypes" class="arch-back hero-item">&larr; All 12 archetypes</a>
          <h1 class="arch-hero-title hero-item">{data.name}</h1>
          <p class="arch-hero-aka hero-item">Also known as {data.aka.join(', ')}</p>
          <p class="arch-hero-tagline hero-item">{data.tagline}</p>
          <div class="arch-hero-actions hero-item">
            <a href="/quiz" class="btn btn--quiz">Is this your archetype? Take the quiz</a>
          </div>
        </div>
        <div class="arch-hero-badge hero-photo-animate">
          {icon && <Image src={icon} alt={`${data.name} brand archetype icon`} width={140} height={140} loading="eager" />}
          <span class="arch-desire-label">Core desire</span>
          <span class="arch-desire">{data.coreDesire}</span>
        </div>
      </div>
    </section>

    <!-- ============================================================
         EMOTIONS BAR
    ============================================================ -->
    <div class="arch-emotions-bar">
      <div class="container arch-emotions-inner">
        <span class="arch-emotions-label">Evokes</span>
        <div class="arch-emotions">
          {data.emotions.map((e) => (
            <span class="tag">{e}</span>
          ))}
        </div>
      </div>
    </div>

    <!-- ============================================================
         BODY
    ============================================================ -->
    <Section variant="default" size="xl">
      <div class="arch-body-grid">
        <div class="arch-prose">
          <Content />
        </div>
        <aside class="arch-aside">
          <div class="aside-card">
            <h2 class="arch-aside-title">Core values</h2>
            <ul class="arch-values">
              {data.values.map((v) => (
                <li>{v}</li>
              ))}
            </ul>
          </div>
          <div class="aside-card">
            <h2 class="arch-aside-title">{data.name} brands</h2>
            <ul class="arch-brands">
              {data.brandExamples.map((b) => (
                <li><strong>{b.name}</strong>{b.note && <span>: {b.note}</span>}</li>
              ))}
            </ul>
            {data.realExamples.length > 0 && (
              <p class="arch-real">Real-life {data.name.replace('The ', '')}s: {data.realExamples.join(', ')}</p>
            )}
          </div>
        </aside>
      </div>
    </Section>

    <!-- ============================================================
         BEST FIT
    ============================================================ -->
    <Section variant="warm" size="xl">
      <p class="label reveal" style="margin-bottom: var(--space-4);">Is this you?</p>
      <h2 class="reveal" style="max-width: 24ch;">{data.name} could be your archetype if...</h2>
      <ul class="arch-fit-grid" data-stagger>
        {data.bestFor.map((item) => (
          <li class="arch-fit-item reveal">{item}</li>
        ))}
      </ul>
      <div class="reveal" style="margin-top: var(--space-12);">
        <a href="/quiz" class="btn btn--quiz">Confirm it with the quiz</a>
      </div>
    </Section>

    <!-- ============================================================
         OTHER ARCHETYPES
    ============================================================ -->
    <Section variant="default" size="lg">
      <p class="label reveal" style="margin-bottom: var(--space-8);">Explore the other archetypes</p>
      <div class="arch-siblings" data-stagger>
        {siblings.map((s) => (
          <a href={`/brand-archetypes/${s.data.slug}`} class="arch-sibling reveal">
            <Image src={icons[s.data.icon]} alt="" width={32} height={32} loading="lazy" />
            <span>{s.data.name.replace('The ', '')}</span>
          </a>
        ))}
      </div>
    </Section>

  </main>

  <Footer />

</BaseLayout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12 }
  );

  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>

<style>
  @keyframes hero-fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero-item {
    animation: hero-fade-up 0.8s cubic-bezier(0.55, 0.21, 0.07, 0.87) both;
  }
  .hero-item:nth-child(1) { animation-delay:  80ms; }
  .hero-item:nth-child(2) { animation-delay: 160ms; }
  .hero-item:nth-child(3) { animation-delay: 240ms; }
  .hero-item:nth-child(4) { animation-delay: 320ms; }
  .hero-item:nth-child(5) { animation-delay: 400ms; }

  @media (prefers-reduced-motion: reduce) {
    .hero-item { animation: none; }
  }

  /* ============================================================
     HERO
  ============================================================ */
  .arch-hero {
    background-color: var(--color-cream);
    padding-block: var(--space-10) var(--space-12);
  }

  .arch-hero-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-16);
    align-items: center;
  }

  .arch-back {
    font-family: var(--ff-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-gold);
    display: inline-block;
    margin-bottom: var(--space-6);
  }

  .arch-hero-title {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    line-height: var(--leading-tight);
    letter-spacing: 0.01em;
  }

  .arch-hero-aka {
    margin-top: var(--space-3);
    font-size: var(--text-base);
    color: var(--gray-600);
    font-style: italic;
  }

  .arch-hero-tagline {
    margin-top: var(--space-5);
    font-size: var(--text-xl);
    color: var(--gray-700);
    line-height: var(--leading-relaxed);
    max-width: 52ch;
  }

  .arch-hero-actions {
    margin-top: var(--space-8);
  }

  .btn--quiz {
    --btn-bg-color: var(--color-gold);
    --btn-border-color: var(--color-gold);
  }

  .arch-hero-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-10) var(--space-12);
    background-color: var(--color-ink);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .arch-desire-label {
    margin-top: var(--space-4);
    font-family: var(--ff-body);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-gold);
  }

  .arch-desire {
    font-family: var(--ff-display);
    font-size: var(--text-xl);
    color: var(--color-cream);
    line-height: var(--leading-snug);
    max-width: 16ch;
  }

  /* ============================================================
     EMOTIONS BAR
  ============================================================ */
  .arch-emotions-bar {
    background-color: var(--color-forest);
    padding-block: var(--space-6);
  }

  .arch-emotions-inner {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .arch-emotions-label {
    font-family: var(--ff-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-gold);
  }

  .arch-emotions {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  /* ============================================================
     BODY
  ============================================================ */
  .arch-body-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: var(--space-20);
    align-items: start;
  }

  .arch-prose {
    max-width: 65ch;
  }

  .arch-prose :global(h2) {
    font-size: var(--text-2xl);
    margin-top: var(--space-12);
    margin-bottom: var(--space-5);
  }

  .arch-prose :global(h2:first-child) {
    margin-top: 0;
  }

  .arch-prose :global(h3) {
    font-size: var(--text-xl);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .arch-prose :global(p) {
    margin-bottom: var(--space-4);
    line-height: var(--leading-relaxed);
  }

  .arch-prose :global(ul) {
    margin: var(--space-4) 0 var(--space-6);
    padding-left: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .arch-prose :global(li) {
    line-height: var(--leading-relaxed);
  }

  .arch-aside {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    position: sticky;
    top: calc(var(--site-header-height) + var(--space-6));
  }

  .aside-card {
    background-color: var(--color-cream);
    border: 1px solid var(--color-blush);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
  }

  .arch-aside-title {
    font-size: var(--text-lg);
    margin-bottom: var(--space-4);
  }

  .arch-values,
  .arch-brands {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .arch-values li,
  .arch-brands li {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    padding-left: var(--space-5);
    position: relative;
  }

  .arch-values li::before,
  .arch-brands li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 8px;
    height: 2px;
    background-color: var(--color-gold);
  }

  .arch-real {
    margin-top: var(--space-5);
    font-size: var(--text-sm);
    color: var(--gray-600);
    line-height: var(--leading-relaxed);
  }

  /* ============================================================
     BEST FIT
  ============================================================ */
  .arch-fit-grid {
    list-style: none;
    padding: 0;
    margin-top: var(--space-12);
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4) var(--space-10);
  }

  .arch-fit-item {
    position: relative;
    padding-left: var(--space-8);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
  }

  .arch-fit-item::before {
    content: '✓';
    position: absolute;
    left: 0;
    top: 0;
    color: var(--color-gold);
    font-weight: var(--weight-semi);
  }

  /* ============================================================
     SIBLINGS
  ============================================================ */
  .arch-siblings {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .arch-sibling {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-5);
    border: 1px solid var(--color-blush);
    border-radius: var(--radius-full);
    font-family: var(--ff-body);
    font-size: var(--text-base);
    color: var(--color-ink);
    transition: border-color var(--duration-base) var(--easing-standard),
                background-color var(--duration-base) var(--easing-standard);
  }

  .arch-sibling:hover {
    border-color: var(--color-gold);
    background-color: rgba(153, 97, 22, 0.06);
  }

  /* ============================================================
     RESPONSIVE
  ============================================================ */
  @media (max-width: 1023px) {
    .arch-body-grid {
      grid-template-columns: 1fr;
      gap: var(--space-12);
    }

    .arch-aside {
      position: static;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-6);
    }
  }

  @media (max-width: 767px) {
    .arch-hero-inner {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }

    .arch-hero-badge {
      justify-self: start;
    }

    .arch-aside {
      grid-template-columns: 1fr;
    }

    .arch-fit-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
