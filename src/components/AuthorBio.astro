---
import { Image } from 'astro:assets';
import kayePhoto from '../assets/kaye-fw.jpg';
---

<div class="author-bio">
  <div class="author-photo">
    <Image
      src={kayePhoto}
      alt="Kaye Putnam"
      width={96}
      height={96}
      loading="lazy"
    />
  </div>
  <div class="author-info">
    <p class="author-label">Written by</p>
    <p class="author-name">Kaye Putnam</p>
    <p class="author-desc">Brand strategist at the intersection of psychology, positioning, and AI. 15 years and 250K+ brand quiz takers later, I'm still obsessed with what makes a brand stick.</p>
    <a href="https://www.linkedin.com/in/kayeputnam/" target="_blank" rel="noopener noreferrer" class="author-link">Connect on LinkedIn →</a>
  </div>
</div>

<style>
  .author-bio {
    display: grid;
    grid-template-columns: 96px 1fr;
    gap: var(--space-6);
    align-items: start;
  }

  .author-photo {
    width: 96px;
    height: 96px;
    border-radius: var(--radius-full);
    overflow: hidden;
    background-color: var(--gray-200);
  }

  .author-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .author-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semi);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: var(--space-1);
  }

  .author-name {
    font-family: var(--ff-heading);
    font-size: var(--text-xl);
    color: var(--color-ink);
    margin-bottom: var(--space-2);
  }

  .author-desc {
    font-size: var(--text-md);
    color: var(--gray-700);
    line-height: var(--leading-relaxed);
    max-width: none;
  }

  .author-link {
    display: inline-block;
    margin-top: var(--space-3);
    font-size: var(--text-sm);
    font-weight: var(--weight-semi);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--gray-400);
    transition: color var(--duration-base) var(--easing-standard);
  }

  .author-link:hover {
    color: var(--color-gold);
  }

  @media (max-width: 767px) {
    .author-bio {
      grid-template-columns: 72px 1fr;
      gap: var(--space-4);
    }

    .author-photo {
      width: 72px;
      height: 72px;
    }
  }
</style>
