---
interface Props {
  title: string;
  excerpt?: string;
  href: string;
  eyebrow?: string;
  tag?: string;
  image?: string;
  imageAlt?: string;
  class?: string;
}

const { title, excerpt, href, eyebrow, tag, image, imageAlt = '', class: className } = Astro.props;
---

<a href={href} class:list={['card', className]}>
  {image && (
    <div class="card-image">
      <img src={image} alt={imageAlt} loading="lazy" />
    </div>
  )}
  <div class="card-body">
    {(eyebrow || tag) && (
      <div class="card-meta">
        {eyebrow && <span class="label">{eyebrow}</span>}
        {tag && <span class="tag">{tag}</span>}
      </div>
    )}
    <h3 class="card-title">{title}</h3>
    {excerpt && <p class="card-excerpt">{excerpt}</p>}
    <span class="card-cta">Read more →</span>
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-lg);
    background-color: var(--gray-100);
    border: 1px solid rgba(209, 198, 190, 0.5);
    overflow: hidden;
    transition: transform var(--duration-base) var(--easing-standard),
                box-shadow var(--duration-base) var(--easing-standard);
    color: var(--color-ink);
  }

  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(18, 24, 27, 0.08);
  }

  .card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background-color: var(--gray-200);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--easing-standard);
  }

  .card:hover .card-image img {
    transform: scale(1.04);
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
    flex: 1;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .card-title {
    font-size: var(--text-xl);
    line-height: var(--leading-snug);
  }

  .card-excerpt {
    font-size: var(--text-md);
    color: var(--gray-700);
    line-height: var(--leading-relaxed);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    max-width: none;
  }

  .card-cta {
    margin-top: auto;
    padding-top: var(--space-3);
    font-family: var(--ff-body);
    font-size: var(--text-base);
    font-weight: var(--weight-semi);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-gold);
  }
</style>
