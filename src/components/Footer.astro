---

<footer class="site-footer">
  <div class="container footer-inner">

    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <img src="/kaye-logo-white.png" alt="Kaye Putnam" class="footer-logo-img" />
        </a>
        <p class="footer-tagline">Helping brands find the clarity that changes everything.</p>
      </div>

      <div class="footer-right">
        <nav class="footer-nav" aria-label="Footer navigation">
          <ul role="list">
            {links.map(link => (
              <li>
                <a
                  href={link.href}
                  class="footer-link"
                  target={link.external ? '_blank' : undefined}
                  rel={link.external ? 'noopener noreferrer' : undefined}
                >{link.label}</a>
              </li>
            ))}
          </ul>
        </nav>
        <div class="footer-socials">
          {socials.map(s => (
            <a href={s.href} target="_blank" rel="noopener noreferrer" class="footer-social" aria-label={s.label}>
              <Fragment set:html={s.icon} />
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">&copy; {new Date().getFullYear()} Kaye Putnam. All rights reserved.</p>
      <nav class="footer-legal" aria-label="Legal">
        <a href="/privacy" class="footer-legal-link">Privacy Policy</a>
        <span class="footer-legal-sep" aria-hidden="true">&middot;</span>
        <a href="/terms" class="footer-legal-link">Terms & Conditions</a>
      </nav>
    </div>

  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-forest);
    color: var(--color-blush);
  }

  .footer-inner {
    padding-block: var(--space-16) var(--space-8);
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-12);
    padding-bottom: var(--space-12);
    border-bottom: 1px solid rgba(209, 198, 190, 0.15);
  }

  .footer-logo {
    display: block;
    margin-bottom: var(--space-4);
  }

  .footer-logo-img {
    height: 48px;
    width: auto;
    opacity: 0.9;
    transition: opacity var(--duration-base) var(--easing-standard);
  }

  .footer-logo:hover .footer-logo-img {
    opacity: 1;
  }

  .footer-tagline {
    font-size: var(--text-base);
    color: var(--color-blush);
    line-height: var(--leading-relaxed);
    opacity: 0.7;
    max-width: 28ch;
  }

  .footer-nav ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    text-align: right;
  }

  .footer-link {
    font-family: var(--ff-body);
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-blush);
    opacity: 0.7;
    transition: opacity var(--duration-base) var(--easing-standard),
                color var(--duration-base) var(--easing-standard);
  }

  .footer-link:hover {
    color: var(--color-gold);
    opacity: 1;
  }

  .footer-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-6);
  }

  .footer-socials {
    display: flex;
    gap: var(--space-4);
  }

  .footer-social {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-full);
    color: var(--color-blush);
    opacity: 0.5;
    transition:
      opacity var(--duration-base) var(--easing-standard),
      color var(--duration-base) var(--easing-standard);
  }

  .footer-social:hover {
    color: var(--color-gold);
    opacity: 1;
  }

  .footer-social svg {
    display: block;
  }

  .footer-bottom {
    padding-top: var(--space-8);
  }

  .footer-copy {
    font-size: var(--text-sm);
    color: var(--color-blush);
    opacity: 0.7;
    letter-spacing: 0.04em;
    max-width: none;
  }

  .footer-legal {
    margin-top: var(--space-3);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .footer-legal-link {
    font-size: var(--text-sm);
    color: var(--color-blush);
    opacity: 0.7;
    letter-spacing: 0.04em;
    transition: opacity var(--duration-base) var(--easing-standard);
  }

  .footer-legal-link:hover {
    opacity: 0.7;
  }

  .footer-legal-sep {
    font-size: var(--text-sm);
    color: var(--color-blush);
    opacity: 0.3;
  }

  @media (max-width: 767px) {
    .footer-top {
      flex-direction: column;
      gap: var(--space-8);
    }

    .footer-right {
      align-items: flex-start;
    }

    .footer-nav ul {
      text-align: left;
      flex-direction: row;
      flex-wrap: wrap;
      gap: var(--space-4) var(--space-6);
    }
  }
</style>
